# =============================================================
# AWS SQL Server (RDS) connection — copy to .env and fill in.
# .env is gitignored; never commit real secrets.
# =============================================================

# RDS endpoint (no port), e.g. assetmgmt.abcdefg12345.ap-southeast-1.rds.amazonaws.com
DB_SERVER=your-instance.xxxxxxxx.region.rds.amazonaws.com
DB_PORT=1433
DB_NAME=AssetMgmt

# RDS master/admin SQL login
DB_USER=admin
DB_PASSWORD=your-strong-password

# TrustServerCertificate=True skips cert validation (fine for dev / RDS default cert).
DB_TRUST_CERT=True

# Hangfire jobs database (often same server, different db)
HANGFIRE_DB_NAME=AssetMgmt_Hangfire

# JWT signing secret (HS256). Must be at least 32 chars. Generate a strong random value.
JWT_SECRET=change-me-to-a-strong-random-secret-at-least-32-chars
