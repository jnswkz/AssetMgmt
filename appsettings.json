{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "AssetMgmt",
    "Audience": "AssetMgmtClient",
    "AccessTokenMinutes": 10,
    "RefreshTokenDays": 7
  },
  "Ai": {
    "RouterModel": "gpt-5.4-nano",
    "ManualSources": [
      {
        "Title": "Dell XPS 13 Support Documents",
        "Url": "https://www.dell.com/support/home/en-us/product-support/",
        "Kind": "support",
        "Manufacturer": "Dell",
        "Model": "XPS 13",
        "Keywords": [ "dell", "xps", "xps 13", "manual", "guide", "support", "documents" ]
      }
    ]
  },
  "Storage": {
    "HandoverRoot": "private/handovers"
  },
  "HangfireDashboard": {
    "Enabled": false
  }
}
